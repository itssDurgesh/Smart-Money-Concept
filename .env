# ============================================================
# SMC Pattern Detector — Environment Configuration
# ============================================================

# --- MySQL Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=1234
DB_NAME=smc_detector

# --- Telegram Alerts (optional — can configure later) ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- FastAPI Dashboard ---
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=True

# --- ML Model ---
MODEL_PATH=models/xgb_smc.pkl
CONFIDENCE_THRESHOLD=0.70

# --- Data Ingestion Defaults ---
DEFAULT_PAIRS=EURUSD,XAUUSD,GBPUSD
DEFAULT_TIMEFRAME=1H
LOOKBACK_DAYS=365
